# ANI 开发环境变量模板
# 复制为 .env 并修改后，各服务自动加载
# 警告：.env 文件不得提交到版本控制（已加入 .gitignore）

# ── 数据库 ────────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://ani:ani_dev_password@localhost:5432/ani?sslmode=disable

# ── 对象存储 ──────────────────────────────────────────────────────────────────
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=ani-admin
MINIO_SECRET_KEY=ani_dev_password
MINIO_USE_SSL=false

# ── 消息队列 ──────────────────────────────────────────────────────────────────
NATS_URL=nats://localhost:4222

# ── 缓存 ──────────────────────────────────────────────────────────────────────
REDIS_URL=redis://:ani_dev_password@localhost:6379/0

# ── 向量数据库 ────────────────────────────────────────────────────────────────
MILVUS_ADDR=localhost:19530

# ── 认证 ──────────────────────────────────────────────────────────────────────
# JWT 签名密钥（生产环境使用 RSA 私钥文件，开发环境使用此对称密钥）
JWT_SECRET=dev_only_change_in_production_32chars!

# OIDC（开发时可留空，使用内置 mock 账号）
OIDC_ISSUER=http://localhost:5556/dex
OIDC_CLIENT_ID=ani-console
OIDC_CLIENT_SECRET=ani-console-secret

# ── ANI Gateway ───────────────────────────────────────────────────────────────
GATEWAY_PORT=8080
GATEWAY_ENV=development
LOG_LEVEL=debug

# ── RAG 引擎 ──────────────────────────────────────────────────────────────────
EMBEDDING_MODEL=BAAI/bge-m3
# HuggingFace 镜像站（国内加速）
HF_ENDPOINT=https://hf-mirror.com

# ── 模型仓库 ──────────────────────────────────────────────────────────────────
# ANI Gateway 内部地址（供 Init Container 使用）
ANI_GATEWAY_INTERNAL_URL=http://ani-gateway.ani-system.svc.cluster.local:8080
